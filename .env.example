# ═══════════════════════════════════════════════════
# AI评分 API 配置
# 支持所有 OpenAI 兼容接口
# ═══════════════════════════════════════════════════

# API Key（设置后启用 AI 评分，未设置则使用规则评分或 Mock 模式）
AI_API_KEY=sk-your-api-key-here

# API 端点（兼容 OpenAI 格式的任何服务）
# OpenAI 官方:      https://api.openai.com/v1
# Azure OpenAI:     https://<resource>.openai.azure.com/v1
# Ollama (本地):    http://localhost:11434/v1
# vLLM:             http://localhost:8000/v1
# Groq:             https://api.groq.com/openai/v1
# DeepSeek:         https://api.deepseek.com/v1
# 通义千问:         https://dashscope.aliyuncs.com/compatible-mode/v1
# 智谱:             https://open.bigmodel.cn/api/paas/v4
AI_API_ENDPOINT=https://api.openai.com/v1

# 模型名称（取决于使用的 API）
# OpenAI: gpt-4o-mini, gpt-4o, gpt-4-turbo
# Ollama: qwen2.5:7b, llama3.1:8b, deepseek-r1:8b
# DeepSeek: deepseek-chat, deepseek-reasoner
# 通义千问: qwen-max, qwen-plus
# 智谱: glm-4-plus, glm-4-flash
AI_MODEL=gpt-4o-mini

# 选择 AI 提供商（仅当使用非 OpenAI 标准格式时需要修改）
# openai    - 所有 OpenAI 兼容接口（默认）
# anthropic - Anthropic Claude（需同时配置 ANTHROPIC_API_KEY）
AI_PROVIDER=openai

# Anthropic Claude API（仅当 AI_PROVIDER=anthropic 时需要）
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# ═══════════════════════════════════════════════════
# 注意：
# - 未配置 API Key 时将自动使用模拟评分（mock 模式）
# - 在 Web 答题系统中，可以在评分方式步骤切换使用规则评分或 AI 评分
# - 规则评分无需 API Key，基于关键词匹配本地运行
# - 修改配置后需重启服务器生效
# - 也可在运行时通过 Web 界面 PUT /api/ai-config 动态更新
# ═══════════════════════════════════════════════════
